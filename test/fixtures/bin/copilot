#!/usr/bin/env bash
# Fake GitHub Copilot CLI for tests. Mimics the subset we use.
case "$1" in
  --version)
    echo "copilot/1.0.59 (fake test stub)"
    exit 0
    ;;
esac

# Optional call counter: append one line per invocation so tests can assert
# how many times the CLI was called (e.g. the JSON retry path).
if [[ -n "$COPILOT_STUB_CALLS" ]]; then
  echo "call" >> "$COPILOT_STUB_CALLS"
fi

args="$*"
if [[ "$args" == *"READY"* ]]; then
  echo "READY"
  exit 0
fi

if [[ "$args" == *"BIGOUTPUT"* ]]; then
  for i in $(seq 1 2000); do
    echo "LINE $i ----------------------------------------------------------------"
  done
  exit 0
fi

case "$COPILOT_STUB_MODE" in
  json-clean)
    echo '{"verdict":"approve","summary":"No issues found.","findings":[],"next_steps":[]}'
    exit 0
    ;;
  json-findings)
    cat <<'EOF'
{"verdict":"needs-attention","summary":"One issue found.","findings":[{"severity":"high","title":"Example","body":"Example finding from stub reviewer.","file":"a.txt","line_start":2,"line_end":2,"confidence":0.9,"recommendation":"Fix it."}],"next_steps":["Fix the issue."]}
EOF
    exit 0
    ;;
  json-malformed)
    echo 'not actually json {'
    exit 0
    ;;
esac

cat <<'EOF'
## Summary
One potential issue found in the diff.

## High
- `a.txt:2` — example finding from stub reviewer.
EOF
exit 0
